<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="user_engagement_report" pageWidth="842" pageHeight="595"
              orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <field name="username" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>
    <field name="totalBooks" class="java.lang.Long"/>
    <field name="booksRead" class="java.lang.Long"/>
    <field name="booksToRead" class="java.lang.Long"/>
    <field name="friendsCount" class="java.lang.Long"/>
    <field name="recommendationsSent" class="java.lang.Long"/>
    <field name="averageRating" class="java.lang.Double"/>
    <field name="reviewsWritten" class="java.lang.Long"/>

    <title>
        <band height="70">
            <staticText>
                <reportElement x="0" y="0" width="802" height="30"/>
                <textElement textAlignment="Center">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[User Engagement Report]]></text>
            </staticText>
            <textField pattern="MMMMM dd, yyyy">
                <reportElement x="0" y="40" width="802" height="20"/>
                <textElement textAlignment="Center">
                    <font size="12"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="40">
            <staticText>
                <reportElement x="0" y="0" width="80" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Username]]></text>
            </staticText>
            <staticText>
                <reportElement x="80" y="0" width="120" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Email]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="0" width="60" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Books]]></text>
            </staticText>
            <staticText>
                <reportElement x="260" y="0" width="60" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Books Read]]></text>
            </staticText>
            <staticText>
                <reportElement x="320" y="0" width="60" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[To Read]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="60" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Friends]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="0" width="80" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Recommendations Sent]]></text>
            </staticText>
            <staticText>
                <reportElement x="520" y="0" width="80" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Average Rating]]></text>
            </staticText>
            <staticText>
                <reportElement x="600" y="0" width="80" height="40"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Reviews Written]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="25">
            <textField>
                <reportElement x="0" y="0" width="80" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{username}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80" y="0" width="120" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="200" y="0" width="60" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{totalBooks}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="260" y="0" width="60" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{booksRead}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="320" y="0" width="60" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{booksToRead}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="60" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{friendsCount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="440" y="0" width="80" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{recommendationsSent}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.0">
                <reportElement x="520" y="0" width="80" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{averageRating} != null ? $F{averageRating} : 0.0]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="600" y="0" width="80" height="25"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{reviewsWritten}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="30">
            <textField>
                <reportElement x="650" y="10" width="100" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>